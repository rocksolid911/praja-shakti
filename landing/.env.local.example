# PrajaShakti Landing Page — Environment Variables
# Copy this file to .env.local and fill in your values

# Flutter web app URL (local dev default: http://localhost:8080)
# Production: set to your CloudFront/custom domain URL
NEXT_PUBLIC_APP_URL=http://localhost:8080

# Django backend API URL (used if you want live stats on the landing page)
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
